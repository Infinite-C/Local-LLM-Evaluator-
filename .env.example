# ============================================================
# 环境变量模板 — Copy to `.env.local` 或 `.env` 然后按需修改
# Environment variable template — Copy to `.env.local` or `.env`
# ============================================================

# ---- Ollama ----
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_NAME=qwen3.5:9b

# ---- 模型开关（1 = 启用, 0 = 禁用）----
USE_LOCAL_MODEL=1
USE_AWS_BEDROCK_MODEL=0
USE_PORTKEY_MODEL=0
USE_OPENROUTER_MODEL=0
USE_GEMINI_MODEL=0
USE_ANTHROPIC_MODEL=0
USE_MOONSHOT_MODEL=0
USE_AZURE_OPENAI=0
USE_OPENAI_MODEL=0
USE_GROK_MODEL=0
USE_DEEPSEEK_MODEL=0
USE_LITELLM=0

# ---- API Keys（请不要把真实密钥提交到 Git）----
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- 评测脚本通用配置 ----
# 裁判模型（用于 LLM-as-Judge 评测，应与被测模型不同）
JUDGE_MODEL=qwen3:32b

# 生成温度（0.0 = 确定性输出，便于评测可复现）
TEMPERATURE=0.0

# 最大输出 Token 数
MAX_TOKENS=2048

# 请求超时（秒）
REQUEST_TIMEOUT=300
